APP_NAME=Test Case Generator
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8001
DEBUG=true
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require&channel_binding=require
DATABASE_CONNECT_TIMEOUT=30
BACKEND_1_INTEGRATION_MODE=api
BACKEND_1_API_URL=http://localhost:8000/api/v1
BACKEND_1_DATABASE_URL=
# Comma-separated format (a single origin also works):
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

GROQ_API_KEY=
GROQ_MODEL=
GEMINI_API_KEY=
GEMINI_MODEL=
OPENAI_API_KEY=
OPENAI_MODEL=
LLM_PRIMARY_PROVIDER=groq
LLM_FALLBACK_PROVIDERS=gemini,openai
LLM_REQUEST_TIMEOUT_SECONDS=60
LLM_TEMPERATURE=0.2
LLM_MAX_OUTPUT_TOKENS=6000
LLM_PROVIDER_RETRY_COUNT=1

# JSON format is also supported:
# CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
