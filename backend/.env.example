APP_NAME=Test Case Generator
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8001
DEBUG=true
APP_MOCK_MODE=true
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require&channel_binding=require
DATABASE_CONNECT_TIMEOUT=30
REDIS_CACHE_ENABLED=true
REDIS_URL=redis://127.0.0.1:6379/0
REDIS_KEY_PREFIX=testcase-generator:v1
REDIS_CONNECT_TIMEOUT_SECONDS=2
REDIS_WORKFLOW_TTL_SECONDS=86400
REDIS_SCRIPT_TTL_SECONDS=86400
BACKEND_1_INTEGRATION_MODE=api
BACKEND_1_API_URL=http://localhost:8000/api/v1
BACKEND_1_DATABASE_URL=
# Comma-separated format (a single origin also works):
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

CEREBRAS_API_KEY=
CEREBRAS_FALLBACK_API_KEY=
CEREBRAS_MODEL=gpt-oss-120b
CEREBRAS_FALLBACK_MODEL=gpt-oss-120b
CEREBRAS_GENERATION_MODEL=
CEREBRAS_VALIDATION_MODEL=
CEREBRAS_REGENERATION_MODEL=
LLM_REQUEST_TIMEOUT_SECONDS=45
LLM_TEMPERATURE=0.2
LLM_MAX_OUTPUT_TOKENS=6000
LLM_GENERATION_MAX_OUTPUT_TOKENS=1500
LLM_VALIDATION_MAX_OUTPUT_TOKENS=2000
LLM_REGENERATION_MAX_OUTPUT_TOKENS=3000
LLM_STRUCTURED_OUTPUT_REPAIR_ENABLED=false
LLM_SCENARIO_BATCH_SIZE=5
LLM_TESTCASE_BATCH_SIZE=5
CEREBRAS_MAX_CONCURRENT_REQUESTS=1
CEREBRAS_PROVIDER_RETRY_COUNT=0
CEREBRAS_INITIAL_BACKOFF_SECONDS=2
CEREBRAS_MAX_BACKOFF_SECONDS=10
CEREBRAS_MIN_REQUEST_INTERVAL_SECONDS=15
CEREBRAS_QUOTA_COOLDOWN_SECONDS=60
LLM_PROVIDER_RETRY_COUNT=3
LLM_RATE_LIMIT_BACKOFF_SECONDS=2
LLM_RATE_LIMIT_JITTER_SECONDS=0.25
LLM_RATE_LIMIT_FALLBACK_THRESHOLD_SECONDS=10

# JSON format is also supported:
# CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# Optional local image analysis
IMAGE_UPLOAD_ENABLED=true
IMAGE_MAX_SIZE_MB=10
IMAGE_MAX_WIDTH=4096
IMAGE_MAX_HEIGHT=4096
IMAGE_ALLOWED_TYPES=image/png,image/jpeg,image/webp
IMAGE_STORAGE_BACKEND=local
IMAGE_STORAGE_PATH=./storage/images
OCR_PROVIDER=paddleocr
OCR_LANGUAGE=en
OCR_MIN_CONFIDENCE=0.60
UI_DETECTOR_PROVIDER=yolo
YOLO_MODEL_PATH=./ml/models/ui_detector.onnx
YOLO_MIN_CONFIDENCE=0.50
YOLO_IOU_THRESHOLD=0.45
YOLO_DEVICE=cpu
ENABLE_HEURISTIC_UI_DETECTION=true
ENABLE_VISION_LLM_FALLBACK=false
VISION_LLM_MIN_LOCAL_CONFIDENCE=0.60
VISION_LLM_MAX_CALLS_PER_IMAGE=1
IMAGE_ANALYSIS_CACHE_ENABLED=true
IMAGE_ANALYSIS_CACHE_TTL_SECONDS=604800
AUTOMATION_ARTIFACTS_PATH=./artifacts/automation
AUTOMATION_NAVIGATION_TIMEOUT_SECONDS=30
AUTOMATION_ACTION_TIMEOUT_SECONDS=10
AUTOMATION_NAVIGATION_SETTLE_TIMEOUT_SECONDS=3
AUTOMATION_WAIT_FOR_NETWORK_IDLE=false
SKYVERN_FALLBACK_ENABLED=false
SKYVERN_INTEGRATION_MODE=self_hosted
SKYVERN_BASE_URL=http://localhost:8000
SKYVERN_API_KEY=
SKYVERN_TIMEOUT_SECONDS=30
SKYVERN_MAX_ATTEMPTS=1
SKYVERN_MAX_CALLS_PER_TEST=2
SKYVERN_MAX_CALLS_PER_RUN=20
