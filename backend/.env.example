APP_NAME=Test Case Generator
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8001
DEBUG=true
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require&channel_binding=require
DATABASE_CONNECT_TIMEOUT=30
BACKEND_1_INTEGRATION_MODE=api
BACKEND_1_API_URL=http://localhost:8000/api/v1
BACKEND_1_DATABASE_URL=
# Comma-separated format (a single origin also works):
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

CEREBRAS_API_KEY=
CEREBRAS_MODEL=gpt-oss-120b
CEREBRAS_GENERATION_MODEL=
CEREBRAS_VALIDATION_MODEL=
CEREBRAS_REGENERATION_MODEL=
GROQ_API_KEY=
GROQ_MODEL=
GROQ_MAX_OUTPUT_TOKENS=1500
GEMINI_API_KEY=
GEMINI_MODEL=
OPENAI_API_KEY=
OPENAI_MODEL=
LLM_PRIMARY_PROVIDER=cerebras
GROQ_GENERATION_MODEL=llama-3.1-8b-instant
GROQ_VALIDATION_MODEL=openai/gpt-oss-120b
GROQ_REGENERATION_MODEL=openai/gpt-oss-120b
GROQ_GENERATION_STRUCTURED_OUTPUT=false
GROQ_VALIDATION_STRUCTURED_OUTPUT=true
GROQ_REGENERATION_STRUCTURED_OUTPUT=true
GEMINI_GENERATION_MODEL=
GEMINI_VALIDATION_MODEL=
GEMINI_REGENERATION_MODEL=
OPENAI_GENERATION_MODEL=
OPENAI_VALIDATION_MODEL=
OPENAI_REGENERATION_MODEL=
LLM_FALLBACK_PROVIDERS=openai,gemini,groq
LLM_REQUEST_TIMEOUT_SECONDS=60
LLM_TEMPERATURE=0.2
LLM_MAX_OUTPUT_TOKENS=6000
LLM_GENERATION_MAX_OUTPUT_TOKENS=1500
LLM_VALIDATION_MAX_OUTPUT_TOKENS=2000
LLM_REGENERATION_MAX_OUTPUT_TOKENS=3000
LLM_SCENARIO_BATCH_SIZE=1
LLM_TESTCASE_BATCH_SIZE=1
CEREBRAS_MAX_CONCURRENT_REQUESTS=1
CEREBRAS_PROVIDER_RETRY_COUNT=1
CEREBRAS_INITIAL_BACKOFF_SECONDS=2
CEREBRAS_MAX_BACKOFF_SECONDS=10
CEREBRAS_MIN_REQUEST_INTERVAL_SECONDS=2
GROQ_CONCURRENCY=1
GEMINI_CONCURRENCY=4
OPENAI_CONCURRENCY=4
LLM_PROVIDER_RETRY_COUNT=1
LLM_RATE_LIMIT_BACKOFF_SECONDS=1
LLM_RATE_LIMIT_JITTER_SECONDS=0.25
LLM_RATE_LIMIT_FALLBACK_THRESHOLD_SECONDS=10

# JSON format is also supported:
# CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
